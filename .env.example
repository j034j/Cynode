HOST=127.0.0.1
PORT=3000

# Default (SQLite)
DATABASE_URL=file:./dev.db

# PostgreSQL
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/cynode?schema=public

# MySQL
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/cynode

# Security Configuration
# Comma-separated list of allowed hosts (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# CORS Configuration
# Comma-separated list of allowed origins (no spaces), use * for all
CORS_ORIGINS=*

# Stripe (for billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ULTRA=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# GitHub OAuth
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
# GITHUB_CALLBACK_URL=https://yourdomain.com/auth/github/callback

# Turso (for production DB)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=...

# App URL
# APP_BASE_URL=https://yourdomain.com
