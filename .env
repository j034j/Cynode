HOST=127.0.0.1
PORT=3001

# LOCAL DEVELOPMENT - Use SQLite file
# DATABASE_URL=file:C:/dev0/cynode/server/prisma/dev.db
DATABASE_URL=file:./dev.db

# FOR VERCEL PRODUCTION - Use Turso by setting DATABASE_URL to:
# DATABASE_URL=libsql://nodex-j034j.aws-eu-west-1.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# Security Configuration
# Comma-separated list of allowed hosts (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# CORS Configuration
# Comma-separated list of allowed origins (no spaces), use * for all
CORS_ORIGINS=*

# Stripe (for billing) - Add your keys here
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ULTRA=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# GitHub OAuth - Add your keys here
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
# GITHUB_CALLBACK_URL=http://127.0.0.1:3000/auth/github/callback

# Turso (for production DB) - Add your credentials here
TURSO_DATABASE_URL=libsql://nodex-j034j.aws-eu-west-1.turso.io
