{
  "manifest_version": 3,
  "name": "Node Graph URL Manager",
  "version": "1.0",
  "description": "Manage and sequence web pages with a visual node graph",
  "permissions": [
    "tabs",
    "bookmarks",
    "history"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Node Graph URL Manager"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
